# Populi billing extract — local environment.
# Copy this file to ".env" in the same folder and fill in your real key.
# The real .env is gitignored and never leaves your machine or enters the repo.
#
#   cp .env.example .env            # PowerShell: Copy-Item .env.example .env
#
# Required ----------------------------------------------------------------
POPULI_API_KEY=sk_your_key_here
POPULI_SCHOOL=turnerseminary
#
# Optional ----------------------------------------------------------------
# Defaults cover all of FY26 (2025-07-01 .. 2026-06-30). Override to change the range.
# POPULI_FY_START=2025-07-01
# POPULI_FY_END=2026-06-30
# OUT=populi-revenue-by-account.xlsx
